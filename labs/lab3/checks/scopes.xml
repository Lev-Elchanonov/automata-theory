<PROGRAM>
    <VARDECLARATION>
        <VAR name="x" CONST="false">
            <TYPE>INT</TYPE>
        </VAR>
    </VARDECLARATION>

    <FUNC name="func2">
        <VARDECLARATION>
            <VAR name="local_x" CONST="false">
                <TYPE>INT</TYPE>
            </VAR>
        </VARDECLARATION>
        <ASSIGN>
            <VALUE>2</VALUE>
            <TO>local_x</TO>
        </ASSIGN>
        <ASSIGN>
            <VALUE>local_x</VALUE>
            <TO>x</TO>
        </ASSIGN>
        <DOWN>
            <VALUE>x</VALUE>
        </DOWN>
    </FUNC>

    <FUNC name="func1">
        <VARDECLARATION>
            <VAR name="local_x" CONST="false">
                <TYPE>INT</TYPE>
            </VAR>
        </VARDECLARATION>
        <ASSIGN>
            <VALUE>2</VALUE>
            <TO>local_x</TO>
        </ASSIGN>
        <CALL>func2</CALL>
        <ASSIGN>
            <VALUE>local_x</VALUE>
            <TO>x</TO>
        </ASSIGN>
        <RIGHT>
            <VALUE>x</VALUE>
        </RIGHT>
    </FUNC>

    <FUNC name="main">
        <ASSIGN>
            <VALUE>2</VALUE>
            <TO>x</TO>
        </ASSIGN>
        <CALL>func1</CALL>
        <UP>
            <VALUE>x</VALUE>
        </UP>
    </FUNC>

</PROGRAM>